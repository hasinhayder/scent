{
  "name": "scent-cli",
  "version": "1.2.0",
  "description": "CLI tool to look up fragrance profiles from Fragrantica",
  "type": "module",
  "bin": {
    "scent-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hasinhayder/scent.git"
  },
  "bugs": {
    "url": "https://github.com/hasinhayder/scent/issues"
  },
