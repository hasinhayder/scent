    "fuse.js": "^7.4.2",
    "ora": "^9.4.1",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
